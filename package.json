{
  "name": "local-llm-desktop-pet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Windows desktop pet app connected to a local Ollama LLM.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "check": "npm run typecheck && npm run lint",
    "audit": "npm audit",
    "verify": "npm run check && npm run build && npm run audit",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "electron-is-dev": "^3.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.10",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "concurrently": "^9.2.1",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.localllm.desktoppet",
    "productName": "Local LLM Desktop Pet",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
